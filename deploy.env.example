# Deploy configuration — copy to deploy.env and fill in your values.
# deploy.env is in .gitignore — never commit real credentials.

# SSH connection
GW_HOST=root@<your-server-ip>
GW_SSH_KEY=/path/to/ssh/private/key

# Server paths (defaults work for standard OmniRoute setup)
GW_REMOTE_GATEWAY_DIR=/opt/claude-gateway
GW_REMOTE_OMNIROUTE_DIR=/opt/omniroute
